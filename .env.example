# RaagFlow — Environment Variables
# Copy this file to .env and fill in your API keys
# Never commit .env to Git

# YouTube Data API v3
# Get from: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
VITE_YOUTUBE_API_KEY=your_youtube_api_key_here

# SoundCloud API
# Get from: https://developers.soundcloud.com
VITE_SOUNDCLOUD_CLIENT_ID=your_soundcloud_client_id_here

# Jamendo API (optional - has a public demo key built in)
# Get from: https://developer.jamendo.com
VITE_JAMENDO_CLIENT_ID=b6747d04
